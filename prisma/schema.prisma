// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String  @id @default(cuid())
  email            String  @unique
  firstName        String
  lastName         String
  password         String?
  phone            String?
  address          String?
  profession       String?
  role             Role    @default(user)
  stripeCustomerId String?

  aiCreditsThisMonth Int       @default(0)
  aiLastUsedAt       DateTime?
  aiCreditsTotal     Int       @default(0)

  resumesThisMonth      Int       @default(0)
  resumeLastGeneratedAt DateTime?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  resumes      Resume[]
  subscription Subscription?
  payments     Payment[]
}

enum Role {
  user
  admin
}

model Resume {
  id           String        @id @default(cuid())
  personalInfo PersonalInfo?
  skills       Skills?
  education    Education[]
  experiences  Experience[]
  projects     Project[]

  type             ResumeType        @default(modern)
  generatedResumes GeneratedResume[]

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  chat Chat?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model GeneratedResume {
  id      String @id @default(cuid())
  aiModel String
  content Json
  version Int    @default(1)

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  message Message?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model PersonalInfo {
  id       String @id @default(cuid())
  fullName String
  email    String
  phone    String
  address  String

  resumeId String @unique
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Education {
  id            String  @id @default(cuid())
  university    String
  degree        String
  fieldOfStudy  String
  startDate     String
  endDate       String?
  stillStudying Boolean @default(false)

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Experience {
  id           String  @id @default(cuid())
  company      String
  position     String
  description  String?
  startDate    String
  endDate      String?
  stillWorking Boolean @default(false)

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Skills {
  id        String   @id @default(cuid())
  soft      String[]
  languages String[]
  technical String[]

  resumeId String @unique
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Project {
  id          String @id @default(cuid())
  title       String
  description String

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

enum ResumeType {
  classic
  modern
  creative
  executive
}

model Chat {
  id       String    @id @default(cuid())
  messages Message[]

  resumeId String @unique
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Message {
  id      String @id @default(cuid())
  content String
  sender  Sender @default(user)

  generatedResumeId String?          @unique
  generatedResume   GeneratedResume? @relation(fields: [generatedResumeId], references: [id], onDelete: Cascade)

  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

enum Sender {
  user
  ai
}

model Plan {
  id                String   @id @default(cuid())
  name              PlanName @unique
  recommended       Boolean  @default(false)
  description       String
  totalResumes      Int      @default(1)
  aiCreditsPerMonth Int      @default(5)

  features            String[]
  detailedDescription String
  additionalFeatures  String[]

  priceMonthly    Int
  stripePriceId   String @unique
  stripeProductId String @unique

  subscriptions Subscription[]

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

enum PlanName {
  free
  pro
  enterprise
}

model Subscription {
  id                   String                   @id @default(cuid())
  stripeSubscriptionId String?                  @unique
  status               StripeSubscriptionStatus

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  planId String
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum StripeSubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  UNPAID
  CANCELED
  INCOMPLETE
}

model Payment {
  id                   String @id @default(cuid())
  stripeSubscriptionId String @unique
  invoice              String

  amount   Int
  currency String
  status   PaymentStatus

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

enum PaymentStatus {
  REQUIRES_PAYMENT_METHOD
  REQUIRES_CONFIRMATION
  PROCESSING
  SUCCEEDED
  FAILED
}
